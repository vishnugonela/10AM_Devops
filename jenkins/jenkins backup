pipeline {
    agent { label 'built-in' }   // run on controller

    stages{

        stage('Backup Jenkins Home'){
            steps{
                sh '''
                    set -e   # stop if any command fails

                    echo "===== Starting Jenkins Backup ====="

                    # Set backup location (use /tmp if permission issue)
                    BACKUP_DIR=/tmp/jenkins_backup
                    DATE=$(date +%F-%H-%M)

                    mkdir -p $BACKUP_DIR

                    # Verify Jenkins home
                    if [ -z "$JENKINS_HOME" ]; then
                        echo "ERROR: JENKINS_HOME is not set"
                        exit 1
                    fi

                    echo "JENKINS_HOME: $JENKINS_HOME"

                    # Take backup
                    tar -czf $BACKUP_DIR/jenkins-backup-$DATE.tar.gz $JENKINS_HOME

                    echo "Backup stored at $BACKUP_DIR"
                '''
            }
        }

        stage('Cleanup Old Backups'){
            steps {
                sh '''
                    echo "===== Cleaning Old Backups ====="

                    find /tmp/jenkins_backup -type f -name "*.tar.gz" -mtime +7 -delete || true

                    echo "Cleanup completed"
                '''
            }
        }
    }

    post {
        success {
            echo "Backup completed successfully"
        }
        failure {
            echo "Backup failed - check logs"
        }
    }
}
